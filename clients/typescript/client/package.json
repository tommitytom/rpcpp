{
  "name": "@rpcpp/client",
  "version": "0.1.0",
  "description": "TypeScript client for rpc++ JSON-RPC 2.0 servers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build":     "tsc",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "typescript":  "^5.5.0",
    "@types/node": "^20.0.0",
    "vitest":      "^2.0.0"
  }
}
