{
  "name": "@rpcpp/codegen",
  "version": "0.1.0",
  "description": "Generate TypeScript types and Zod schemas from rpcpp's OpenRPC schema",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "rpcpp-codegen": "./src/cli.ts"
  },
  "scripts": {
    "codegen":   "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod":                "^3.23.0",
    "@types/json-schema": "^7.0.15",
    "tsx":                "^4.19.0"
  },
  "devDependencies": {
    "typescript":  "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
